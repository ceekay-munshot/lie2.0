{
  "name": "lie-detector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lie Detector — extract, verify and score measurable management promises for Indian listed companies.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "validate": "node pipeline/validate.mjs",
    "validate:manifest": "node pipeline/validate-manifest.mjs",
    "validate:corpus": "node pipeline/validate-corpus.mjs",
    "gen:index": "node pipeline/gen-index.mjs",
    "scrape": "node pipeline/scrape-screener.mjs",
    "ingest:upload": "node pipeline/ingest-upload.mjs",
    "ingest": "node pipeline/ingest.mjs",
    "extract": "node pipeline/extract.mjs",
    "verify": "node pipeline/verify.mjs",
    "eval:verify": "node pipeline/eval-verification.mjs",
    "test:ingest": "node pipeline/test/p3.test.mjs",
    "test:extract": "node pipeline/test/p4.test.mjs",
    "test:verify": "node pipeline/test/p5.test.mjs",
    "llm:selftest": "node pipeline/lib/llm.mjs --selftest"
  },
  "engines": {
    "node": ">=20"
  },
  "comment": "Pipeline + validation deps (ajv, ajv-formats, wrangler, ...) are installed with `npm install --no-save <pkg>`; they are intentionally NOT listed here and node_modules/ is gitignored."
